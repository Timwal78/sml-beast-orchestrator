# sml-beast-orchestrator — required env

# Live SERP data — Serper.dev (real subscription key, no fallback)
SERPER_API_KEY=

# HMAC secret used by the internal x402 facilitator-proxy to sign/verify
# the X-PAYMENT envelopes minted for internal workers. Rotate periodically.
# openssl rand -hex 32
X402_PROXY_SECRET=

# x402 protocol surface
X402_NETWORK=base-sepolia
X402_PAY_TO=0x4e14B249D9A4c9c9352D780eCEB508A8eB7a7700
X402_SERP_PRICE_USDC=0.001

# Proxy bind
X402_PROXY_HOST=127.0.0.1
X402_PROXY_PORT=4020

# ── Dashboard auth ──────────────────────────────────────────────────────────
# Required for the operator dashboard to register routes. Failure-closed:
# without this the dashboard does not exist as a routable surface.
# Generate: openssl rand -hex 32
DASHBOARD_AUTH_TOKEN=

# ── BB7 outreach agent (no custody — fire-and-forget Payment only) ──────────
# Wallet seed that signs the unconditional 5 USDC demo Payment transactions.
# NEVER commit a real seed. The agent refuses to start without it. Use a
# dedicated hot wallet, NOT your primary operational wallet. See SECURITY.md
# for the cold/hot split.
BB7_XRPL_WALLET_SEED=
# "testnet" or "mainnet". Stay on testnet until operator signs off on
# the first 5 outreach pitches (manual review gate per BB7_DESIGN.md §6).
BB7_XRPL_NETWORK=testnet
# SMTP relay for outreach@infrastructure.scriptmasterlabs.com. Operator
# brings their own MX — Postmark, SendGrid, AWS SES, etc. Required to
# send pitches; agent refuses to start without it.
BB7_SMTP_HOST=
BB7_SMTP_PORT=587
BB7_SMTP_USER=
BB7_SMTP_PASS=
BB7_SMTP_FROM=outreach@infrastructure.scriptmasterlabs.com

# Output directory (defaults to ./output)
BEAST_OUTPUT_ROOT=

LOG_LEVEL=INFO

# BB8 Social Broadcaster (X.com)
# ------------------------------------------------------------------------------
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_TOKEN_SECRET=""

