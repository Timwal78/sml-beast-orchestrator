# sml-beast-orchestrator — required env

# Live SERP data — Serper.dev (real subscription key, no fallback)
SERPER_API_KEY=

# HMAC secret used by the internal x402 facilitator-proxy to sign/verify
# the X-PAYMENT envelopes minted for internal workers. Rotate periodically.
# openssl rand -hex 32
X402_PROXY_SECRET=

# x402 protocol surface
X402_NETWORK=base-sepolia
X402_PAY_TO=0x4e14B249D9A4c9c9352D780eCEB508A8eB7a7700
X402_SERP_PRICE_USDC=0.001

# Proxy bind
X402_PROXY_HOST=127.0.0.1
X402_PROXY_PORT=4020

# Output directory (defaults to ./output)
BEAST_OUTPUT_ROOT=

LOG_LEVEL=INFO
